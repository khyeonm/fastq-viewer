{
  "name": "fastq-viewer",
  "version": "1.0.2",
  "description": "FASTQ read viewer with per-base quality score heatmap, Q-score distribution, and read length statistics",
  "extensions": [
    "fastq",
    "fq"
  ],
  "entry": "index.js",
  "style": "style.css",
  "data_source": {
    "type": "text",
    "row_count": "awk 'NR%4==1' '{file}' | wc -l",
    "metadata": "head -1 '{file}'",
    "rows": "awk -v s={start} -v e={end} 'NR%4==1{{n++}} n>=s&&n<e{{print; for(i=1;i<=3;i++){{getline;print}}}}' '{file}'",
    "col_headers": [],
    "meta_parse": "none",
    "allow_nonzero_exit": false,
    "fallback": [
      {
        "type": "docker",
        "image": "ubuntu:22.04",
        "row_count": "awk 'NR%4==1' '{file}' | wc -l",
        "metadata": "head -1 '{file}'",
        "rows": "awk -v s={start} -v e={end} 'NR%4==1{{n++}} n>=s&&n<e{{print; for(i=1;i<=3;i++){{getline;print}}}}' '{file}'",
        "col_headers": [],
        "meta_parse": "none",
        "allow_nonzero_exit": false
      }
    ]
  }
}
